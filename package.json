{
  "name": "fwd-rag-demo",
  "version": "1.0.0",
  "description": "Agentic RAG demo for insurance policy Q&A with MCP, tenant isolation, and AI safety guardrails",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "seed": "tsx scripts/seed-db.ts",
    "demo": "tsx scripts/demo.ts",
    "verify": "tsx scripts/verify.ts",
    "test": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:evals": "vitest run tests/evals/",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rag",
    "insurance",
    "mcp",
    "ai-safety",
    "pgvector"
  ],
  "author": "Manik Soin",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.30",
    "@langchain/openai": "^1.2.12",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "langfuse": "^3.38.6",
    "openai": "^6.25.0",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
